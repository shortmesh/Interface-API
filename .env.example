# Server Configuration
# Host the server will bind to
HOST=127.0.0.1
# Port the server will listen on
PORT=8080
# Logging level for application output (debug, info, warn, error)
LOG_LEVEL=info

# Database Configuration
# SQLite database file path
SQLITE_DB_PATH=./data/shortmesh.db

# Migration Settings
# Automatically run pending database migrations on application startup
AUTO_MIGRATE=true

# Cryptographic Keys
# Base64-encoded 32-byte key used for HMAC hashing of tokens (session tokens, API keys)
HASH_KEY=
# Passphrase for database encryption at rest using SQLCipher
# Use hex encoding for better entropy (recommended: 64 hex characters = 256 bits)
# Generate with: openssl rand -hex 32
DB_ENCRYPTION_KEY=

# External Services
# Base URL for the Matrix Authentication Service
MAS_URL=
# URL for the Matrix Authentication Service (admin endpoint)
MAS_ADMIN_URL=
# Client ID used for authenticating with MAS as an admin client
ADMIN_CLIENT_ID=
# Client secret used for authenticating with MAS as an admin client
ADMIN_CLIENT_SECRET=
# Base URL for the Matrix client
MATRIX_CLIENT_URL=

# RabbitMQ Configuration
# Connection URL for RabbitMQ message broker
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
