# Server Configuration
# Application mode: 'development' or 'production'
# Production mode enforces HTTPS for external services and server (unless overridden)
APP_MODE=development
# Host the server will bind to
HOST=127.0.0.1
# Port the server will listen on
PORT=8080
# Logging level for application output (debug, info, warn, error)
LOG_LEVEL=info

# TLS/HTTPS Configuration (required in production mode unless ALLOW_INSECURE_SERVER is set)
# Path to TLS certificate file
TLS_CERT_FILE=
# Path to TLS private key file
TLS_KEY_FILE=

# Security Overrides (use with caution in production)
# Allow server to run without HTTPS in production mode (e.g., behind reverse proxy with TLS termination)
ALLOW_INSECURE_SERVER=false
# Allow connections to external services over non-HTTPS protocols in production mode
ALLOW_INSECURE_EXTERNAL=false

# Database Configuration
# SQLite database file path
SQLITE_DB_PATH=./data/shortmesh.db

# Migration Settings
# Automatically run pending database migrations on application startup
AUTO_MIGRATE=true

# Cryptographic Keys
# Base64-encoded 32-byte key used for HMAC hashing of tokens (session tokens, API keys)
HASH_KEY=
# Passphrase for database encryption at rest using SQLCipher
# Use hex encoding for better entropy (recommended: 64 hex characters = 256 bits)
# Generate with: openssl rand -hex 32
DB_ENCRYPTION_KEY=

# External Services
# Base URL for the Matrix Authentication Service
MAS_URL=
# URL for the Matrix Authentication Service (admin endpoint)
MAS_ADMIN_URL=
# Client ID used for authenticating with MAS as an admin client
ADMIN_CLIENT_ID=
# Client secret used for authenticating with MAS as an admin client
ADMIN_CLIENT_SECRET=
# Base URL for the Matrix client
MATRIX_CLIENT_URL=

# RabbitMQ Configuration
# Connection URL for RabbitMQ message broker
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
